# ─── AutoInvest — root .env for docker-compose ──────────────────────────────
# Copy this file to .env and fill in the values before running docker-compose.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-random-32-character-string!!

# ── Application ────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── CORS — comma-separated list of allowed frontend origins ──────────────────
# Change to the public URL of your frontend when deploying.
CORS_ORIGINS=http://localhost

# ── Frontend API URL ──────────────────────────────────────────────────────────
# URL that the browser will use to reach the backend.
# When running with docker-compose locally this is the host machine's address.
VITE_API_URL=http://localhost:8000/api/v1

# ── External API Keys ─────────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_news_api_key
GEMINI_API_KEY=your_gemini_api_key
POLYGON_API_KEY=your_polygon_api_key
OPENAI_API_KEY=
